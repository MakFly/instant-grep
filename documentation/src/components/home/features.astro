<section class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-xs font-mono uppercase tracking-widest feat-orange mb-3">Techniques</p>
      <h2 class="text-3xl sm:text-4xl font-mono font-bold text-foreground mb-4">
        Forbidden jutsu built into the CLI
      </h2>
      <p class="text-muted-foreground max-w-xl mx-auto">
        Six core techniques, each mastered to perfection. No bloat, no compromise — pure search power.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((feature) => (
        <div class="energy-card rounded-xl p-6 bg-card/50 flex flex-col gap-4">
          <div class="flex items-start justify-between">
            <div class={`w-12 h-12 rounded-xl flex items-center justify-center text-2xl feat-icon-bg ${feature.cls}`}>
              {feature.icon}
            </div>
            <span class={`text-xs font-mono px-2 py-1 rounded-full feat-badge ${feature.cls}`}>
              {feature.subtitle}
            </span>
          </div>

          <div>
            <h3 class="font-mono font-bold text-foreground text-lg mb-2">{feature.title}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Color classes */
  .feat-orange { color: var(--primary); }
  .feat-blue { color: var(--accent); }
  .feat-gold { color: oklch(0.55 0.14 80); }
  .feat-red { color: oklch(0.55 0.2 25); }
  .feat-green { color: oklch(0.52 0.14 155); }

  :global(.dark) .feat-orange { color: #FF9500; }
  :global(.dark) .feat-blue { color: #00B4FF; }
  :global(.dark) .feat-gold { color: #FFD700; }
  :global(.dark) .feat-red { color: #FF6B5A; }

  /* Icon background */
  .feat-icon-bg {
    background: color-mix(in oklch, currentColor 15%, transparent);
    border: 1px solid color-mix(in oklch, currentColor 30%, transparent);
  }

  /* Badge */
  .feat-badge {
    background: color-mix(in oklch, currentColor 15%, transparent);
    border: 1px solid color-mix(in oklch, currentColor 20%, transparent);
  }
</style>
