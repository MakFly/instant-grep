---
---

<section class="py-20 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-xs font-mono uppercase tracking-widest term-orange mb-3">Live Demo</p>
      <h2 class="text-3xl font-mono font-bold gradient-text">See the jutsu in action</h2>
    </div>

    <div class="code-block rounded-xl overflow-hidden shadow-2xl term-shadow">
      <!-- Terminal title bar -->
      <div class="flex items-center gap-2 px-4 py-3 bg-secondary/50 border-b border-border">
        <div class="w-3 h-3 rounded-full bg-[#FF3B30]"></div>
        <div class="w-3 h-3 rounded-full bg-[#FFD700]"></div>
        <div class="w-3 h-3 rounded-full bg-[#34C759]"></div>
        <span class="ml-3 text-xs text-muted-foreground/50 font-mono">instant-grep — terminal</span>
        <div class="ml-auto flex items-center gap-1.5">
          <span class="text-xs term-blue font-mono animate-pulse">● CHAKRA ACTIVE</span>
        </div>
      </div>

      <!-- Terminal content -->
      <div class="p-6 font-mono text-sm space-y-3 min-h-[320px]">
        <!-- Command 1: index -->
        <div class="flex gap-2">
          <span class="term-orange select-none">❯</span>
          <span class="text-foreground/90">ig index .</span>
        </div>
        <div class="text-muted-foreground/70 pl-4 space-y-1 text-xs">
          <div><span class="term-blue">◆</span> Gathering chakra... indexing 1,247 files</div>
          <div><span class="term-gold">◆</span> Building sparse n-gram index</div>
          <div><span class="term-green">✓</span> Index built: <span class="text-foreground/80">147ms</span> · <span class="term-gold">2.3 MB</span> · stored in <span class="term-blue">.ig/</span></div>
        </div>

        <!-- Command 2: search -->
        <div class="flex gap-2 pt-2">
          <span class="term-orange select-none">❯</span>
          <span class="text-foreground/90">ig <span class="term-gold">"async fn"</span> src/</span>
        </div>
        <div class="text-muted-foreground/70 pl-4 space-y-1 text-xs">
          <div class="term-blue">src/daemon.rs<span class="text-muted-foreground/40">:23:</span></div>
          <div class="pl-4 text-foreground/60">pub <span class="term-orange-bright">async fn</span> handle_connection(stream: UnixStream) {"{"}</div>
          <div class="term-blue">src/index/writer.rs<span class="text-muted-foreground/40">:89:</span></div>
          <div class="pl-4 text-foreground/60">pub <span class="term-orange-bright">async fn</span> build_index(path: &Path) -> Result{"<"}(){">"} {"{"}</div>
          <div class="term-blue">src/query/extract.rs<span class="text-muted-foreground/40">:14:</span></div>
          <div class="pl-4 text-foreground/60">pub <span class="term-orange-bright">async fn</span> run_query(pattern: &str) -> Vec{"<"}Match{">"} {"{"}</div>
          <div class="mt-2 pt-2 border-t border-border/30">
            <span class="term-green">✓</span> <span class="text-foreground/80">3 matches</span> in <span class="term-gold font-bold">0.9ms</span> <span class="text-muted-foreground/40">·</span> <span class="text-muted-foreground/60">47 candidates filtered</span>
          </div>
        </div>

        <!-- Command 3: daemon query -->
        <div class="flex gap-2 pt-2">
          <span class="term-orange select-none">❯</span>
          <span class="text-foreground/90">ig query <span class="term-gold">"Result&lt;"</span> . <span class="text-muted-foreground/50">--json</span></span>
        </div>
        <div class="text-muted-foreground/70 pl-4 text-xs">
          <div><span class="term-green">✓</span> Daemon query: <span class="term-orange font-bold">0.3ms</span> <span class="text-muted-foreground/40">·</span> <span class="text-foreground/80">12 matches</span></div>
        </div>

        <!-- Prompt + caret -->
        <div class="flex gap-2 pt-2">
          <span class="term-orange select-none">❯</span>
          <span class="terminal-cursor text-foreground/30"></span>
        </div>
      </div>
    </div>

    <!-- Stats under terminal -->
    <div class="grid grid-cols-3 gap-4 mt-6">
      <div class="text-center p-4 rounded-lg border border-border/30 bg-secondary/30">
        <div class="text-xl font-mono font-bold term-orange">0.9ms</div>
        <div class="text-xs text-muted-foreground mt-1 font-mono">p50 latency</div>
      </div>
      <div class="text-center p-4 rounded-lg border border-border/30 bg-secondary/30">
        <div class="text-xl font-mono font-bold term-blue">0.3ms</div>
        <div class="text-xs text-muted-foreground mt-1 font-mono">daemon mode</div>
      </div>
      <div class="text-center p-4 rounded-lg border border-border/30 bg-secondary/30">
        <div class="text-xl font-mono font-bold term-gold">20×</div>
        <div class="text-xs text-muted-foreground mt-1 font-mono">vs V1 baseline</div>
      </div>
    </div>
  </div>
</section>

<style>
  .term-orange { color: var(--primary); }
  .term-orange-bright { color: var(--primary); }
  .term-blue { color: var(--accent); }
  .term-gold { color: oklch(0.55 0.14 80); }
  .term-green { color: oklch(0.52 0.14 155); }

  .term-shadow { box-shadow: 0 0 60px color-mix(in oklch, var(--accent) 10%, transparent), 0 0 120px color-mix(in oklch, var(--primary) 5%, transparent); }

  :global(.dark) .term-orange { color: #FF6B00; }
  :global(.dark) .term-orange-bright { color: #FF9500; }
  :global(.dark) .term-blue { color: #00B4FF; }
  :global(.dark) .term-gold { color: #FFD700; }
  :global(.dark) .term-green { color: #34C759; }
  :global(.dark) .term-shadow { box-shadow: 0 0 60px rgba(0,180,255,0.1), 0 0 120px rgba(255,107,0,0.05); }
</style>
