---
---

<section class="relative min-h-[90vh] flex flex-col items-center justify-center px-6 overflow-hidden">
  <!-- Background grid -->
  <div
    class="absolute inset-0 hero-grid opacity-[0.03]"
  ></div>

  <!-- Background radial glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full hero-glow"></div>

  <!-- Floating orbs (ki energy) -->
  <div class="absolute top-20 left-20 w-3 h-3 rounded-full hero-orb-orange opacity-60 animate-float" style="animation-delay: 0s;"></div>
  <div class="absolute top-32 right-32 w-2 h-2 rounded-full hero-orb-blue opacity-50 animate-float" style="animation-delay: 0.7s;"></div>
  <div class="absolute bottom-40 left-40 w-2.5 h-2.5 rounded-full hero-orb-gold opacity-40 animate-float" style="animation-delay: 1.4s;"></div>
  <div class="absolute bottom-32 right-24 w-2 h-2 rounded-full hero-orb-orange opacity-50 animate-float" style="animation-delay: 2.1s;"></div>
  <div class="absolute top-1/2 left-10 w-1.5 h-1.5 rounded-full hero-orb-blue opacity-40 animate-float" style="animation-delay: 0.5s;"></div>

  <div class="relative z-10 flex flex-col items-center text-center max-w-4xl gap-6">
    <!-- Badge -->
    <div class="hero-badge flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-mono">
      <span class="w-1.5 h-1.5 rounded-full hero-orb-orange animate-pulse"></span>
      Trigram-indexed regex search · Rust · 20 tests passing
    </div>

    <!-- Main title -->
    <h1 class="font-mono font-black text-5xl sm:text-7xl lg:text-8xl leading-none tracking-tight">
      <span class="gradient-text text-glow-orange">instant</span>
      <span class="text-foreground/90">-</span>
      <span class="gradient-text text-glow-orange">grep</span>
    </h1>

    <!-- Tagline -->
    <p class="text-xl sm:text-2xl text-muted-foreground max-w-2xl leading-relaxed">
      <span class="hero-accent-blue">Faster than Instant Transmission.</span>
      <br />
      <span class="hero-accent-gold">Sharper than a Rasengan.</span>
    </p>

    <!-- Stats row -->
    <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-8 my-4">
      <div class="flex flex-col items-center gap-1">
        <span class="font-mono text-3xl font-black gradient-text">0.9ms</span>
        <span class="text-xs text-muted-foreground font-mono uppercase tracking-wider">search latency</span>
      </div>
      <div class="w-px h-10 bg-border/50 hidden sm:block"></div>
      <div class="flex flex-col items-center gap-1">
        <span class="font-mono text-3xl font-black hero-stat-blue">20×</span>
        <span class="text-xs text-muted-foreground font-mono uppercase tracking-wider">vs V1 baseline</span>
      </div>
      <div class="w-px h-10 bg-border/50 hidden sm:block"></div>
      <div class="flex flex-col items-center gap-1">
        <span class="font-mono text-3xl font-black hero-stat-gold">20</span>
        <span class="text-xs text-muted-foreground font-mono uppercase tracking-wider">tests passing</span>
      </div>
      <div class="w-px h-10 bg-border/50 hidden sm:block"></div>
      <div class="flex flex-col items-center gap-1">
        <span class="font-mono text-3xl font-black hero-stat-orange">38</span>
        <span class="text-xs text-muted-foreground font-mono uppercase tracking-wider">dirs excluded</span>
      </div>
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center gap-4">
      <a
        href="/docs/getting-started"
        class="group relative inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-mono font-bold text-sm text-primary-foreground overflow-hidden transition-all animate-chakra-pulse hover:scale-105 hero-cta-primary"
      >
        <span class="relative z-10">Get Started</span>
        <svg class="relative z-10 w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a
        href="/docs/cli"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-mono font-bold text-sm text-muted-foreground border border-border/50 hero-cta-secondary transition-all"
      >
        CLI Reference
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="16 18 22 12 16 6"></polyline>
          <polyline points="8 6 2 12 8 18"></polyline>
        </svg>
      </a>
    </div>

    <!-- Quick install -->
    <div class="flex items-center gap-3 px-5 py-2.5 rounded-lg code-block text-xs font-mono">
      <span class="hero-inline-orange">$</span>
      <span class="hero-inline-blue">cargo</span>
      <span class="text-foreground/70">build --release</span>
      <span class="text-muted-foreground/40 mx-1">&&</span>
      <span class="hero-inline-gold">ig</span>
      <span class="text-foreground/70">"pattern" .</span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-muted-foreground/30 animate-float">
    <span class="text-xs font-mono uppercase tracking-widest">Scroll</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </div>
</section>

<style>
  .hero-grid {
    background-image:
      linear-gradient(oklch(0.5 0.15 45 / 0.5) 1px, transparent 1px),
      linear-gradient(90deg, oklch(0.5 0.15 45 / 0.5) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero-glow { background: radial-gradient(circle, oklch(0.5 0.15 45 / 0.06) 0%, oklch(0.5 0.1 250 / 0.03) 40%, transparent 70%); }
  .hero-orb-orange { background-color: var(--primary); }
  .hero-orb-blue { background-color: var(--accent); }
  .hero-orb-gold { background-color: oklch(0.55 0.14 80); }

  .hero-badge {
    border: 1px solid color-mix(in oklch, var(--primary) 35%, oklch(0.88 0.01 75));
    background: color-mix(in oklch, var(--primary) 8%, oklch(0.99 0.002 90));
    color: oklch(0.36 0.12 38);
  }

  .hero-accent-blue { color: var(--accent); }
  .hero-accent-gold { color: oklch(0.55 0.14 80); }

  .hero-stat-blue { color: var(--accent); text-shadow: 0 0 20px color-mix(in oklch, var(--accent) 50%, transparent); }
  .hero-stat-gold { color: oklch(0.55 0.14 80); text-shadow: 0 0 20px oklch(0.55 0.14 80 / 0.5); }
  .hero-stat-orange { color: var(--primary); text-shadow: 0 0 20px color-mix(in oklch, var(--primary) 50%, transparent); }

  .hero-cta-primary { background: linear-gradient(135deg, var(--primary), color-mix(in oklch, var(--primary) 80%, oklch(0.7 0.15 60))); }
  .hero-cta-secondary:hover {
    border-color: color-mix(in oklch, var(--accent) 40%, transparent);
    color: var(--accent);
    background: color-mix(in oklch, var(--accent) 5%, transparent);
  }

  .hero-inline-orange { color: var(--primary); }
  .hero-inline-blue { color: var(--accent); }
  .hero-inline-gold { color: oklch(0.55 0.14 80); }

  :global(.dark) .hero-grid {
    background-image:
      linear-gradient(rgba(255,107,0,0.5) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,107,0,0.5) 1px, transparent 1px);
  }
  :global(.dark) .hero-glow { background: radial-gradient(circle, rgba(255,107,0,0.06) 0%, rgba(0,180,255,0.03) 40%, transparent 70%); }
  :global(.dark) .hero-orb-orange { background-color: #FF6B00; }
  :global(.dark) .hero-orb-blue { background-color: #00B4FF; }
  :global(.dark) .hero-orb-gold { background-color: #FFD700; }
  :global(.dark) .hero-badge { border-color: rgba(255,107,0,0.3); background: rgba(255,107,0,0.05); color: #FF9500; }
  :global(.dark) .hero-accent-blue { color: #00B4FF; }
  :global(.dark) .hero-accent-gold { color: #FFD700; }
  :global(.dark) .hero-stat-blue { color: #00B4FF; text-shadow: 0 0 20px rgba(0,180,255,0.5); }
  :global(.dark) .hero-stat-gold { color: #FFD700; text-shadow: 0 0 20px rgba(255,215,0,0.5); }
  :global(.dark) .hero-stat-orange { color: #FF6B00; text-shadow: 0 0 20px rgba(255,107,0,0.5); }
  :global(.dark) .hero-cta-primary { background: linear-gradient(135deg, #FF6B00, #FF9500); }
  :global(.dark) .hero-cta-secondary:hover { border-color: rgba(0,180,255,0.4); color: #00B4FF; background: rgba(0,180,255,0.05); }
  :global(.dark) .hero-inline-orange { color: #FF6B00; }
  :global(.dark) .hero-inline-blue { color: #00B4FF; }
  :global(.dark) .hero-inline-gold { color: #FFD700; }
</style>
