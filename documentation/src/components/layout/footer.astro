<footer class="border-t border-border/50 py-8 px-6">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted-foreground/60">
    <div class="flex items-center gap-2 font-mono">
      <span class="gradient-text font-bold">instant-grep</span>
      <span>—</span>
      <span>Built with the Will of Fire 🔥</span>
    </div>
    <div class="flex items-center gap-2 font-mono text-xs">
      <span class="footer-orange animate-pulse">⚡</span>
      <span>Over 9000 files indexed per second</span>
    </div>
    <div class="text-xs font-mono">
      <span class="text-muted-foreground/40">MIT License</span>
      <span class="mx-2 text-muted-foreground/20">·</span>
      <a
        href="https://github.com/kevinbdx35/instant-grep"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-link hover:text-primary transition-colors"
      >GitHub</a>
    </div>
  </div>
</footer>

<style>
  .footer-orange { color: var(--primary); }
  .footer-link { color: inherit; }

  :global(.dark) .footer-orange { color: #FF6B00; }
  :global(.dark) .footer-link:hover { color: #FF9500; }
</style>
