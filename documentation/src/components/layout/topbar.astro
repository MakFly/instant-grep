---
const navLinks = [
  { href: "/docs/getting-started", label: "Docs", match: ["/docs/getting-started", "/docs/cli", "/docs/architecture"] },
  { href: "/docs/performance", label: "Performance", match: ["/docs/performance"] },
  { href: "/docs/vs-rtk", label: "vs RTK", match: ["/docs/vs-rtk"] },
  { href: "/docs/embeddings", label: "Embeddings", match: ["/docs/embeddings"] },
]
const path = Astro.url.pathname
const isActive = (link: typeof navLinks[number]) => link.match.some(p => path === p || path.startsWith(p + "/"))
---

<header class="sticky top-0 z-50 w-full border-b border-border/60 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80">
  <div class="mx-auto max-w-7xl">
    <div class="flex h-16 items-center justify-between px-4 md:px-6">
      <!-- Logo + nav -->
      <div class="flex items-center space-x-8">
        <a href="/" class="flex items-center gap-2 font-semibold">
          <span class="flex h-6 w-6 items-center justify-center rounded bg-foreground text-background text-[11px] font-bold">ig</span>
          <span class="text-base">instant-grep</span>
        </a>
        <nav class="hidden md:flex items-center space-x-6 text-sm">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`transition-colors ${isActive(link) ? "text-foreground font-medium" : "text-muted-foreground hover:text-foreground"}`}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Search command + GitHub -->
      <div class="flex items-center gap-2">
        <button
          type="button"
          class="hidden md:inline-flex items-center gap-2 rounded-md border border-border/60 bg-muted/40 px-3 py-1.5 text-xs text-muted-foreground hover:bg-muted hover:text-foreground transition-colors"
          aria-label="Search docs"
          onclick="window.dispatchEvent(new Event('ig-docs-search'))"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <span>Search the docs…</span>
          <kbd class="ml-4 inline-flex items-center gap-0.5 rounded bg-background border border-border/60 px-1.5 py-0.5 text-[10px] font-mono text-muted-foreground">
            <span>⌘</span>K
          </kbd>
        </button>
        <a
          href="https://github.com/MakFly/instant-grep"
          target="_blank"
          rel="noopener"
          class="rounded-md p-2 text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors"
          aria-label="GitHub"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </div>
</header>
