---
interface Props {
  currentPath?: string
}

const { currentPath = "" } = Astro.props

const navItems: {
  section: string
  links: { href: string; label: string; badge?: string }[]
}[] = [
  {
    section: "Overview",
    links: [
      { href: "/docs/getting-started", label: "Getting Started" },
    ],
  },
  {
    section: "Reference",
    links: [
      { href: "/docs/cli", label: "CLI Reference" },
      { href: "/docs/architecture", label: "Architecture" },
    ],
  },
  {
    section: "Advanced",
    links: [
      { href: "/docs/performance", label: "Performance" },
      { href: "/docs/vs-rtk", label: "ig vs RTK" },
      { href: "/docs/embeddings", label: "OpenAI Embeddings", badge: "POC" },
      { href: "/docs/agents", label: "Agent Integration" },
    ],
  },
]

function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href + "/")
}

function isSectionActive(links: { href: string }[]) {
  return links.some((l) => isActive(l.href))
}
---

<aside class="hidden md:block sticky top-16 h-[calc(100vh-4rem)] w-64 flex-shrink-0 border-r border-border/60 overflow-y-auto">
  <nav class="py-8 px-6">
    <a href="/" class="inline-flex items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground transition-colors mb-6">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Back to home
    </a>

    <div class="space-y-1">
      {navItems.map((section) => (
        <details class="group/sec mt-3 first:mt-0" open={isSectionActive(section.links) || true}>
          <summary class="flex w-full cursor-pointer items-center justify-between py-1.5 text-sm font-semibold text-foreground list-none [&::-webkit-details-marker]:hidden">
            <span class="truncate">{section.section}</span>
            <svg class="h-4 w-4 text-muted-foreground transition-transform group-open/sec:rotate-0 -rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </summary>
          <div class="mt-1 space-y-0.5">
            {section.links.map((link) => (
              <a
                href={link.href}
                class={`group flex items-center gap-2 py-1.5 pl-3 text-sm transition-colors ${
                  isActive(link.href)
                    ? "text-foreground font-medium"
                    : "text-muted-foreground hover:text-foreground"
                }`}
              >
                <span class="truncate">{link.label}</span>
                {link.badge && (
                  <span class="inline-flex items-center rounded bg-muted px-1.5 py-0.5 text-[10px] font-medium text-foreground/70">
                    {link.badge}
                  </span>
                )}
              </a>
            ))}
          </div>
        </details>
      ))}
    </div>
  </nav>
</aside>
