---
import MainLayout from "@/layouts/main.astro"
import Topbar from "@/components/layout/topbar.astro"
---

<MainLayout title="404 — Page not found">
  <Topbar />

  <div class="min-h-[80vh] flex flex-col items-center justify-center px-6 text-center">
    <div class="max-w-md">
      <div class="font-mono text-7xl font-semibold text-muted-foreground/30 mb-6">404</div>
      <h1 class="text-xl font-semibold mb-3">Page not found</h1>
      <p class="text-sm text-muted-foreground mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex items-center justify-center gap-3">
        <a href="/" class="inline-flex items-center h-9 px-4 rounded-md bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 transition-colors">
          Back to home
        </a>
        <a href="/docs/getting-started" class="inline-flex items-center h-9 px-4 rounded-md border text-sm font-medium hover:bg-accent transition-colors">
          Read the docs
        </a>
      </div>
    </div>
  </div>

  <footer class="border-t py-6 text-center text-xs text-muted-foreground">
    Built by <a href="https://github.com/MakFly" class="underline hover:text-foreground">MakFly</a> · MIT License
  </footer>
</MainLayout>
