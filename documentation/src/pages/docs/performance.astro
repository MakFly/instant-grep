---
import DocsLayout from "@/layouts/docs.astro"
import { Code } from "astro:components"

const benchmarks = [
  { version: "V1", tool: "ig (V1 — naive trigrams)", latency: "18ms", notes: "Baseline — full trigram scan" },
  { version: "V2", tool: "ig (V2 — index + verification)", latency: "8ms", notes: "Index lookup + regex verify" },
  { version: "V3", tool: "ig (V3 — sparse n-grams)", latency: "3ms", notes: "Sparse n-gram algorithm introduced" },
  { version: "V4", tool: "ig (V4 — covering set + mmap)", latency: "1.4ms", notes: "Covering set selection + mmap" },
  { version: "V5", tool: "ig (V5 — parallel verify)", latency: "0.9ms", notes: "Rayon parallel regex verification" },
  { version: "daemon", tool: "ig (daemon mode)", latency: "0.3ms", notes: "Index held in process memory" },
]

const timeline = [
  {
    label: "V1 — Naive trigrams",
    note: "18ms",
    description: "Baseline implementation. Full trigram scan on every query.",
  },
  {
    label: "V2 — Index + verify",
    note: "8ms",
    description: "Index-based lookup reduces candidates before regex verification.",
  },
  {
    label: "V3 — Sparse n-grams",
    note: "3ms",
    description: "Sparse n-gram algorithm replaces fixed-width trigrams. Variable-length n-grams dramatically improve selectivity.",
  },
  {
    label: "V4 — Covering + mmap",
    note: "1.4ms",
    description: "Covering set selection picks minimal n-gram set. Memory-mapped index avoids loading into RAM.",
  },
  {
    label: "V5 — Parallel verify",
    note: "0.9ms",
    description: "Rayon-powered parallel regex verification across candidate files.",
  },
  {
    label: "Daemon mode",
    note: "0.3ms",
    description: "Index held permanently in process memory. Unix socket queries bypass all startup.",
  },
]

const heroStats = [
  { value: "29/30", label: "Wins vs ripgrep" },
  { value: "93.5%", label: "Token savings (v10)" },
  { value: "4.1x", label: "More compact than RTK" },
  { value: "0.71ms", label: "Daemon mode" },
]

const daemonSteps = [
  { step: "Unix socket read (query)", time: "~0.02ms" },
  { step: "N-gram extraction from regex", time: "~0.05ms" },
  { step: "Hash table lookup (lexicon in memory)", time: "~0.03ms" },
  { step: "Posting list intersection", time: "~0.05ms" },
  { step: "Parallel regex verification", time: "~0.10ms" },
  { step: "Unix socket write (results)", time: "~0.05ms" },
]

const daemonWidths = [7, 17, 10, 17, 33, 17]
---

<DocsLayout title="Performance" description="Benchmarks, optimization history, and why sparse n-grams win">
    <!-- Page header -->
    <div class="mb-10">
      <h1 class="text-3xl font-semibold text-foreground mb-4">
        Performance
      </h1>
      <p class="text-muted-foreground text-lg leading-relaxed">
        From 18ms to 0.9ms — the complete optimization history across five versions.
      </p>
    </div>

    <!-- Hero stats -->
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-12">
      {heroStats.map((stat) => (
        <div class="text-center p-5 rounded-lg border bg-background">
          <div class="text-foreground text-3xl font-semibold mb-1">
            {stat.value}
          </div>
          <div class="text-xs text-muted-foreground">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Benchmark table -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-foreground mb-4">
        Benchmark Table — v1.1.0
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        Measured across 5 real codebases (915-11,350 files). Hardware: Apple M4 Max.
        Best of 3 runs. ig v1.1.0 vs ripgrep 15.1.
      </p>

      <div class="overflow-x-auto border rounded-lg overflow-hidden">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-muted">
              <th class="text-left py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">Query</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">Candidates</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">ig</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">rg</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">Speedup</th>
            </tr>
          </thead>
          <tbody class="text-xs">
            {[
              { query: '"function" (11K files)', candidates: "744 / 1148", ig: "33ms", rg: "39ms", speedup: "1.2x", highlight: true },
              { query: '"class\\s+\\w+" (11K files)', candidates: "836 / 1148", ig: "29ms", rg: "34ms", speedup: "1.2x", highlight: true },
              { query: '"deprecated" (11K files)', candidates: "5 / 1148", ig: "21ms", rg: "31ms", speedup: "1.5x", highlight: false },
              { query: "no-match (11K files)", candidates: "0 / 1148", ig: "20ms", rg: "30ms", speedup: "1.5x", highlight: false },
              { query: '"import" (11K files)', candidates: "—", ig: "24ms", rg: "32ms", speedup: "1.3x", highlight: false },
              { query: '"function" (3K files)', candidates: "—", ig: "40ms", rg: "43ms", speedup: "1.1x", highlight: false },
              { query: '"class\\s+\\w+" (3K files)', candidates: "—", ig: "33ms", rg: "44ms", speedup: "1.3x", highlight: true },
              { query: '"deprecated" (3K files)', candidates: "—", ig: "22ms", rg: "37ms", speedup: "1.7x", highlight: false },
              { query: '"function" (2.5K files)', candidates: "—", ig: "40ms", rg: "47ms", speedup: "1.2x", highlight: false },
              { query: '"todo" -i (2.5K files)', candidates: "—", ig: "21ms", rg: "36ms", speedup: "1.7x", highlight: false },
            ].map((row) => (
              <tr class="border-t border hover:bg-muted">
                <td class="py-3 px-4 text-foreground"><code>{row.query}</code></td>
                <td class="py-3 px-4 text-right text-muted-foreground">{row.candidates}</td>
                <td class="py-3 px-4 text-right font-semibold text-foreground">{row.ig}</td>
                <td class="py-3 px-4 text-right text-muted-foreground">{row.rg}</td>
                <td class="py-3 px-4 text-right font-semibold text-foreground">{row.speedup}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="text-xs text-muted-foreground mt-3 italic">
        * v1.1.0 wins on all patterns including complex regex. Lazy line_starts + raised escape hatch (85%) keep the indexed path efficient.
      </p>
    </section>

    <!-- Daemon benchmarks -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-foreground mb-4">
        Daemon Mode — Server-side Search Times
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        Pure search time inside the daemon process (no process startup, no socket overhead). Laravel app, 1,552 files.
      </p>

      <div class="overflow-x-auto border rounded-lg overflow-hidden">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-muted">
              <th class="text-left py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">Query</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">Candidates</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">Search time</th>
            </tr>
          </thead>
          <tbody class="text-xs">
            {[
              { query: '"DistributionController"', candidates: "2 / 1552", time: "0.08ms", highlight: true },
              { query: '"function"', candidates: "974 / 1552", time: "4.43ms", highlight: false },
              { query: '"exception"', candidates: "39 / 1552", time: "0.75ms", highlight: false },
              { query: '"ZZZNOTFOUND" (zero results)', candidates: "0 / 1552", time: "0.01ms", highlight: false },
              { query: '"middleware"', candidates: "30 / 1552", time: "0.74ms", highlight: false },
              { query: '"Route::"', candidates: "4 / 1552", time: "0.20ms", highlight: false },
              { query: '"class "', candidates: "897 / 1552", time: "3.88ms", highlight: false },
            ].map((row) => (
              <tr class="border-t border hover:bg-muted">
                <td class="py-3 px-4 text-foreground"><code>{row.query}</code></td>
                <td class="py-3 px-4 text-right text-muted-foreground">{row.candidates}</td>
                <td class="py-3 px-4 text-right font-semibold text-foreground">{row.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-5 p-4 rounded-lg border">
        <p class="text-sm text-muted-foreground leading-relaxed">
          The daemon keeps the index mmap'd in process memory — rare/selective patterns like
          <code>"DistributionController"</code> resolve in
          <span class="font-semibold text-foreground">0.08ms</span>. Even zero-result queries short-circuit in
          <span class="font-semibold text-foreground">0.01ms</span>.
        </p>
      </div>
    </section>

    <!-- Index build stats -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-foreground mb-4">
        Index Build — SPIMI Pipeline
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        v1.0.0 uses a SPIMI (Single-Pass In-Memory Indexing) pipeline with a 128MB RAM budget.
        VByte delta-encoded postings reduce postings.bin by ~50-60%.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { label: "Fresh build (1,552 files)", value: "480ms", sub: "2 SPIMI segments" },
          { label: "Incremental (no-op)", value: "28ms", sub: "overlay index" },
          { label: "Total index size", value: "36MB", sub: "lexicon 31MB + postings 7.1MB + metadata 111KB" },
          { label: "Peak RSS", value: "440MB", sub: "streaming pipeline" },
        ].map((stat) => (
          <div class="p-5 rounded-lg border bg-background text-center">
            <div class="text-foreground text-2xl font-semibold mb-1">{stat.value}</div>
            <div class="text-xs text-foreground mb-1">{stat.label}</div>
            <div class="text-xs text-muted-foreground">{stat.sub}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Ecosystem comparison -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-foreground mb-4">
        Ecosystem Comparison
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        Where ig fits among the indexed-search landscape.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="p-5 rounded-lg border-2 border-foreground bg-background relative">
          <div class="absolute top-3 right-3">
            <span class="text-xs px-2 py-0.5 rounded-full bg-muted text-foreground font-semibold">you are here</span>
          </div>
          <div class="text-lg font-semibold text-foreground mb-1">ig</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Sparse n-grams (Blackbird algorithm). Local CLI, open source, standalone.
            Built for agent and editor-adjacent workflows.
          </p>
        </div>
        <div class="p-5 rounded-lg border bg-background">
          <div class="text-lg font-semibold text-foreground mb-1">Cursor</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Same algorithm (sparse n-grams). Integrated in editor, closed source.
            ig brings this power to the CLI.
          </p>
        </div>
        <div class="p-5 rounded-lg border bg-background">
          <div class="text-lg font-semibold text-foreground mb-1">Reflex</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Trigrams + Tree-sitter for semantic awareness. Rust, open source.
            AST-aware queries at the cost of indexing complexity.
          </p>
        </div>
        <div class="p-5 rounded-lg border bg-background">
          <div class="text-lg font-semibold text-foreground mb-1">Zoekt</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Trigrams, server-based (Sourcegraph). Open source.
            Designed for large-scale monorepo search over HTTP.
          </p>
        </div>
        <div class="p-5 rounded-lg border bg-background">
          <div class="text-lg font-semibold text-foreground mb-1">ripgrep</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Brute-force regex, no index. Fastest unindexed tool.
            Great for small repos; ig outpaces it as repo size grows.
          </p>
        </div>
        <div class="p-5 rounded-lg border bg-background">
          <div class="text-lg font-semibold text-foreground mb-1">Trigrep</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Trigrams (Moderne). Cloud-based, closed source.
            Enterprise SaaS — ig is the self-hosted, open alternative.
          </p>
        </div>
      </div>
    </section>

    <!-- Optimization Timeline -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-foreground mb-6">
        Optimization Timeline
      </h2>

      <div class="timeline">
        {timeline.map((item, i) => (
          <div class="flex gap-4 items-start">
            <div class="flex flex-col items-center">
              <div class="w-2.5 h-2.5 rounded-full bg-foreground mt-1.5 flex-shrink-0"></div>
              {i < timeline.length - 1 && (
                <div class="w-px flex-1 bg-border"></div>
              )}
            </div>
            <div class="pb-8">
              <div class="flex items-baseline gap-3 mb-1">
                <span class="text-sm font-semibold">{item.label}</span>
                <span class="font-mono text-sm text-muted-foreground">{item.note}</span>
              </div>
              <p class="text-xs text-muted-foreground">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Why sparse n-grams -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-foreground mb-4">
        Why Sparse N-grams Beat Trigrams
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-6">
        <div class="p-5 rounded-lg border bg-background">
          <div class="text-lg font-semibold text-foreground mb-2">Selectivity</div>
          <p class="text-sm text-muted-foreground">
            Longer n-grams appear in fewer files. A 7-gram like <code>"async f"</code>
            eliminates 99% of files immediately. Trigrams are too common.
          </p>
        </div>
        <div class="p-5 rounded-lg border bg-background">
          <div class="text-lg font-semibold text-foreground mb-2">Index Size</div>
          <p class="text-sm text-muted-foreground">
            Fewer, more selective n-grams per file — smaller posting lists — smaller index.
            ig's index is typically 2-3MB for a 1000+ file project.
          </p>
        </div>
        <div class="p-5 rounded-lg border bg-background">
          <div class="text-lg font-semibold text-foreground mb-2">Intersection</div>
          <p class="text-sm text-muted-foreground">
            Fewer candidates to intersect means less time in the merge step.
            Covering set selection picks the most selective n-grams automatically.
          </p>
        </div>
      </div>

      <div class="code-block rounded-lg p-5">
        <div class="text-xs font-mono text-[oklch(0.6_0_0)] mb-3">Selectivity comparison for "async fn":</div>
        <pre class="font-mono text-xs leading-relaxed overflow-x-auto"><code set:html={`<span class="text-red-400">Trigrams (weak):</span>   "asy"(3000 files) ∩ "syn"(2100 files) ∩ "ync"(1800 files) = 47 candidates
<span class="text-green-400">Sparse n-grams:</span>   "async fn"(3 files) = 3 candidates  → 15x fewer candidates to verify`}></code></pre>
      </div>
    </section>

    <!-- Daemon latency -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-foreground mb-4">
        Daemon Latency Breakdown
      </h2>
      <p class="text-sm text-muted-foreground mb-6">
        Six stages from query to result. Total p50 latency: <strong>0.71ms</strong>.
      </p>

      <div class="space-y-3">
        {daemonSteps.map((item, i) => (
          <div class="flex items-center gap-3">
            <div class="w-56 text-xs text-muted-foreground text-right flex-shrink-0">{item.step}</div>
            <div class="flex-1 flex items-center gap-2">
              <div class="h-6 rounded bg-foreground/10" style={`width: ${daemonWidths[i]}%`}></div>
              <span class="text-xs font-mono text-muted-foreground">{item.time}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="flex items-center gap-3 mt-4 pt-4 border-t">
        <div class="w-56 text-sm font-semibold text-right flex-shrink-0">Total (p50)</div>
        <div class="text-sm font-semibold">0.71ms</div>
      </div>
    </section>

    <!-- Scaling curve -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-foreground mb-4">
        Scaling Curve
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        ig's advantage compounds as project size grows. On small repos it matches rg; on large ones the index dominates.
      </p>

      <div class="overflow-x-auto border rounded-lg overflow-hidden">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-muted">
              <th class="text-left py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">Project</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">Files</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">ig search</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">rg search</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">Speedup</th>
            </tr>
          </thead>
          <tbody class="text-xs">
            {[
              { project: "laravel-app", files: "49", ig: "19ms", rg: "21ms", speedup: "1.1x", highlight: false },
              { project: "distribution-app", files: "1,552", ig: "70ms", rg: "33ms", speedup: "0.5x", highlight: false },
              { project: "Next.js", files: "24,760", ig: "627ms", rg: "1,490ms", speedup: "2.4x", highlight: false },
              { project: "Linux kernel", files: "92,585", ig: "1,290ms", rg: "5,119ms", speedup: "4.0x", highlight: true },
            ].map((row) => (
              <tr class="border-t border hover:bg-muted">
                <td class="py-3 px-4 text-foreground">{row.project}</td>
                <td class="py-3 px-4 text-right text-muted-foreground">{row.files}</td>
                <td class="py-3 px-4 text-right font-semibold text-foreground">{row.ig}</td>
                <td class="py-3 px-4 text-right text-muted-foreground">{row.rg}</td>
                <td class="py-3 px-4 text-right font-semibold text-foreground">{row.speedup}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-4 p-4 rounded-lg border">
        <p class="text-sm text-muted-foreground leading-relaxed">
          On the Linux kernel (92K files), a zero-result search:
          <span class="font-semibold text-foreground">28ms ig</span> vs
          <span class="font-semibold text-muted-foreground">5,279ms rg</span> =
          <span class="font-semibold text-foreground">189x speedup</span>.
        </p>
      </div>
    </section>

    <!-- Daemon latency percentiles -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-foreground mb-4">
        Daemon Latency Percentiles
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        1,001 queries across all patterns. Overall: p50 = 0.71ms, p95 = 4.51ms, p99 = 4.69ms, avg = 1.51ms.
      </p>

      <div class="overflow-x-auto border rounded-lg overflow-hidden">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-muted">
              <th class="text-left py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">Pattern</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">p50</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">p95</th>
              <th class="text-right py-3 px-4 text-xs text-muted-foreground font-normal uppercase tracking-wider">p99</th>
            </tr>
          </thead>
          <tbody class="text-xs">
            {[
              { pattern: '"ZZZNOTFOUND"', p50: "0.01ms", p95: "—", p99: "—", highlight: true },
              { pattern: '"DistributionController"', p50: "0.08ms", p95: "—", p99: "—", highlight: false },
              { pattern: '"Route::"', p50: "0.20ms", p95: "—", p99: "—", highlight: false },
              { pattern: '"middleware"', p50: "0.74ms", p95: "—", p99: "—", highlight: false },
              { pattern: '"exception"', p50: "0.75ms", p95: "—", p99: "—", highlight: false },
              { pattern: '"class "', p50: "3.88ms", p95: "—", p99: "—", highlight: false },
              { pattern: '"function"', p50: "4.43ms", p95: "—", p99: "—", highlight: false },
            ].map((row) => (
              <tr class="border-t border hover:bg-muted">
                <td class="py-3 px-4 text-foreground"><code>{row.pattern}</code></td>
                <td class="py-3 px-4 text-right font-semibold text-foreground">{row.p50}</td>
                <td class="py-3 px-4 text-right text-muted-foreground">{row.p95}</td>
                <td class="py-3 px-4 text-right text-muted-foreground">{row.p99}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Throughput -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-foreground mb-4">
        Throughput
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        End-to-end QPS includes process startup; server-side QPS measures pure daemon throughput.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-6 rounded-lg border bg-background text-center">
          <div class="text-foreground text-3xl font-semibold mb-1">312 QPS</div>
          <div class="text-xs text-foreground mb-1">Effective (with process startup)</div>
          <div class="text-xs text-muted-foreground">CLI round-trip throughput</div>
        </div>
        <div class="p-6 rounded-lg border bg-background text-center">
          <div class="text-foreground text-3xl font-semibold mb-1">2,695 QPS</div>
          <div class="text-xs text-foreground mb-1">Server-side theoretical</div>
          <div class="text-xs text-muted-foreground">Pure daemon query throughput</div>
        </div>
      </div>
    </section>

    <!-- v1.1.0 Changelog -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-foreground mb-4">
        v1.1.0 — What Changed
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        v1.1.0 focuses on search performance and correctness. ig now beats ripgrep on 29/30 benchmark tests.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-5 rounded-lg border bg-background">
          <div class="text-lg font-semibold text-foreground mb-2">Lazy line_starts</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Regex match check runs <strong>before</strong> building the line index.
            False-positive candidates (no matches) bail immediately with zero byte scanning.
            This is the single biggest win for complex regex patterns like <code>class\s+\w+</code>.
          </p>
        </div>
        <div class="p-5 rounded-lg border bg-background">
          <div class="text-lg font-semibold text-foreground mb-2">Early exit modes</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            <code>-l</code> (files_only) returns after the first match — no iteration.
            <code>-c</code> (count_only) counts without building line_starts.
            Both are now significantly faster on files with many matches.
          </p>
        </div>
        <div class="p-5 rounded-lg border bg-background">
          <div class="text-lg font-semibold text-foreground mb-2">Single-file search</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            <code>ig "pattern" file.rs</code> now scopes to that exact file instead of
            searching the entire project. Works with special characters like <code>$.tsx</code>.
          </p>
        </div>
        <div class="p-5 rounded-lg border bg-background">
          <div class="text-lg font-semibold text-foreground mb-2">Parallel fallback + madvise</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Brute-force fallback now uses rayon (was sequential). Binary check reads 8KB
            instead of full file. <code>madvise(MADV_RANDOM)</code> on postings prevents
            useless readahead. Escape hatch raised to 85%.
          </p>
        </div>
      </div>
    </section>

