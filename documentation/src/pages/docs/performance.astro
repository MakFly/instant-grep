---
import DocsLayout from "@/layouts/docs.astro"

const benchmarks = [
  { version: "V1", tool: "ig (V1 — naive trigrams)", latency: "18ms", notes: "Baseline — full trigram scan", cls: "perf-red", highlight: false, goku: false },
  { version: "V2", tool: "ig (V2 — index + verification)", latency: "8ms", notes: "Index lookup + regex verify", cls: "perf-orange", highlight: false, goku: false },
  { version: "V3", tool: "ig (V3 — sparse n-grams)", latency: "3ms", notes: "Rasengan Algorithm introduced", cls: "perf-gold", highlight: false, goku: false },
  { version: "V4", tool: "ig (V4 — covering set + mmap)", latency: "1.4ms", notes: "Shadow Clone Selection + mmap", cls: "perf-blue", highlight: false, goku: false },
  { version: "V5", tool: "ig (V5 — parallel verify)", latency: "0.9ms", notes: "Rayon parallel regex verification", cls: "perf-green", highlight: true, goku: false },
  { version: "daemon", tool: "ig (daemon mode)", latency: "0.3ms", notes: "Sage Mode — index in process memory", cls: "perf-orange", highlight: true, goku: false },
  { version: "goku", tool: "Goku (Instant Transmission)", latency: "0.00ms", notes: "Teleports to any ki signature instantly", cls: "perf-gold", highlight: false, goku: true },
]

const timeline = [
  { label: "V1 — Naive trigrams", ms: 18, cls: "perf-red", note: "18ms" },
  { label: "V2 — Index + verify", ms: 8, cls: "perf-orange", note: "8ms" },
  { label: "V3 — Sparse n-grams", ms: 3, cls: "perf-gold", note: "3ms" },
  { label: "V4 — Covering + mmap", ms: 1.4, cls: "perf-blue", note: "1.4ms" },
  { label: "V5 — Parallel verify", ms: 0.9, cls: "perf-green", note: "0.9ms" },
  { label: "Daemon mode", ms: 0.3, cls: "perf-orange", note: "0.3ms" },
]

const heroStats = [
  { value: "29/30", label: "Wins vs ripgrep", cls: "perf-orange" },
  { value: "20ms", label: "CLI p50 (rare)", cls: "perf-gold" },
  { value: "0.71ms", label: "Daemon mode", cls: "perf-green" },
  { value: "1.5×", label: "Avg speedup vs rg", cls: "perf-orange" },
]

const daemonSteps = [
  { step: "Unix socket read (query)", time: "~0.02ms", cls: "perf-blue" },
  { step: "N-gram extraction from regex", time: "~0.05ms", cls: "perf-orange" },
  { step: "Hash table lookup (lexicon in memory)", time: "~0.03ms", cls: "perf-gold" },
  { step: "Posting list intersection", time: "~0.05ms", cls: "perf-green" },
  { step: "Parallel regex verification", time: "~0.10ms", cls: "perf-orange" },
  { step: "Unix socket write (results)", time: "~0.05ms", cls: "perf-blue" },
]
---

<DocsLayout title="Performance" description="Benchmarks, optimization history, and why sparse n-grams win">
  <div class="max-w-none">
    <!-- Page header -->
    <div class="mb-10">
      <div class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest mb-3 perf-gold">
        <span>📊</span>
        <span>Power Level Chart — Over 9000</span>
      </div>
      <h1 class="text-4xl font-mono font-black mb-4 gradient-text">
        Performance
      </h1>
      <p class="text-muted-foreground text-lg leading-relaxed">
        From 18ms to 0.9ms — the complete optimization saga across five versions.
        Each iteration a new form, each form more powerful than the last.
      </p>
    </div>

    <!-- Hero stats -->
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-12">
      {heroStats.map((stat) => (
        <div class="text-center p-5 rounded-xl energy-card">
          <div class={`font-mono text-3xl font-black mb-1 ${stat.cls}`}>
            {stat.value}
          </div>
          <div class="text-xs text-muted-foreground font-mono">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Benchmark table -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="perf-gold">⚡</span>
        Benchmark Table — v1.1.0
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        Measured across 5 real codebases (915–11,350 files). Hardware: Apple M4 Max.
        Best of 3 runs. ig v1.1.0 vs ripgrep 15.1.
      </p>

      <div class="overflow-x-auto rounded-xl border border-border">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-border bg-secondary/50">
              <th class="text-left py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">Query</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">Candidates</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">ig</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">rg</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">Speedup</th>
            </tr>
          </thead>
          <tbody class="font-mono text-xs">
            {[
              { query: '"function" (11K files)', candidates: "744 / 1148", ig: "33ms", rg: "39ms", speedup: "1.2×", highlight: true },
              { query: '"class\\s+\\w+" (11K files)', candidates: "836 / 1148", ig: "29ms", rg: "34ms", speedup: "1.2×", highlight: true },
              { query: '"deprecated" (11K files)', candidates: "5 / 1148", ig: "21ms", rg: "31ms", speedup: "1.5×", highlight: false },
              { query: "no-match (11K files)", candidates: "0 / 1148", ig: "20ms", rg: "30ms", speedup: "1.5×", highlight: false },
              { query: '"import" (11K files)', candidates: "—", ig: "24ms", rg: "32ms", speedup: "1.3×", highlight: false },
              { query: '"function" (3K files)', candidates: "—", ig: "40ms", rg: "43ms", speedup: "1.1×", highlight: false },
              { query: '"class\\s+\\w+" (3K files)', candidates: "—", ig: "33ms", rg: "44ms", speedup: "1.3×", highlight: true },
              { query: '"deprecated" (3K files)', candidates: "—", ig: "22ms", rg: "37ms", speedup: "1.7×", highlight: false },
              { query: '"function" (2.5K files)', candidates: "—", ig: "40ms", rg: "47ms", speedup: "1.2×", highlight: false },
              { query: '"todo" -i (2.5K files)', candidates: "—", ig: "21ms", rg: "36ms", speedup: "1.7×", highlight: false },
            ].map((row) => (
              <tr class="border-b border-border/50 transition-colors hover:bg-secondary/30">
                <td class="py-3 px-4 text-foreground/80"><code class="font-mono">{row.query}</code></td>
                <td class="py-3 px-4 text-right text-muted-foreground">{row.candidates}</td>
                <td class={`py-3 px-4 text-right font-bold ${row.highlight ? "perf-orange" : "text-foreground/70"}`}>{row.ig}</td>
                <td class="py-3 px-4 text-right text-foreground/70">{row.rg}</td>
                <td class={`py-3 px-4 text-right font-bold ${row.speedup.startsWith("0") ? "perf-red" : "perf-green"}`}>{row.speedup}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="text-xs text-muted-foreground/60 mt-3 font-mono italic">
        * v1.1.0 wins on all patterns including complex regex. Lazy line_starts + raised escape hatch (85%) keep the indexed path efficient.
      </p>
    </section>

    <!-- Daemon benchmarks -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="perf-orange">🐸</span>
        Daemon Mode — Server-side Search Times
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        Pure search time inside the daemon process (no process startup, no socket overhead). Laravel app, 1,552 files.
      </p>

      <div class="overflow-x-auto rounded-xl border border-border">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-border bg-secondary/50">
              <th class="text-left py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">Query</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">Candidates</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">Search time</th>
            </tr>
          </thead>
          <tbody class="font-mono text-xs">
            {[
              { query: '"DistributionController"', candidates: "2 / 1552", time: "0.08ms", highlight: true },
              { query: '"function"', candidates: "974 / 1552", time: "4.43ms", highlight: false },
              { query: '"exception"', candidates: "39 / 1552", time: "0.75ms", highlight: false },
              { query: '"ZZZNOTFOUND" (zero results)', candidates: "0 / 1552", time: "0.01ms", highlight: false },
              { query: '"middleware"', candidates: "30 / 1552", time: "0.74ms", highlight: false },
              { query: '"Route::"', candidates: "4 / 1552", time: "0.20ms", highlight: false },
              { query: '"class "', candidates: "897 / 1552", time: "3.88ms", highlight: false },
            ].map((row) => (
              <tr class="border-b border-border/50 transition-colors hover:bg-secondary/30">
                <td class="py-3 px-4 text-foreground/80"><code class="font-mono">{row.query}</code></td>
                <td class="py-3 px-4 text-right text-muted-foreground">{row.candidates}</td>
                <td class={`py-3 px-4 text-right font-bold ${row.highlight ? "perf-green" : "text-foreground/70"}`}>{row.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-5 p-4 rounded-xl energy-card border border-border/80">
        <p class="text-sm text-muted-foreground leading-relaxed">
          The daemon keeps the index mmap'd in process memory — rare/selective patterns like
          <code class="font-mono">"DistributionController"</code> resolve in
          <span class="font-bold perf-green">0.08ms</span>. Even zero-result queries short-circuit in
          <span class="font-bold perf-green">0.01ms</span>.
        </p>
      </div>
    </section>

    <!-- Index build stats -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="perf-blue">📦</span>
        Index Build — SPIMI Pipeline
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        v1.0.0 uses a SPIMI (Single-Pass In-Memory Indexing) pipeline with a 128MB RAM budget.
        VByte delta-encoded postings reduce postings.bin by ~50–60%.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { label: "Fresh build (1,552 files)", value: "480ms", sub: "2 SPIMI segments", cls: "perf-orange" },
          { label: "Incremental (no-op)", value: "28ms", sub: "overlay index", cls: "perf-green" },
          { label: "Total index size", value: "36MB", sub: "lexicon 31MB + postings 7.1MB + metadata 111KB", cls: "perf-blue" },
          { label: "Peak RSS", value: "440MB", sub: "streaming pipeline — Linux kernel RSS: 6.8 GB (-62%)", cls: "perf-gold" },
        ].map((stat) => (
          <div class="p-5 rounded-xl energy-card text-center">
            <div class={`font-mono text-2xl font-black mb-1 ${stat.cls}`}>{stat.value}</div>
            <div class="text-xs font-mono text-foreground/70 mb-1">{stat.label}</div>
            <div class="text-xs text-muted-foreground/60">{stat.sub}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Ecosystem comparison -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="perf-blue">🌐</span>
        Ecosystem Comparison
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        Where ig fits among the indexed-search landscape.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="p-5 rounded-xl energy-card border-2 border-primary/40 relative">
          <div class="absolute top-3 right-3">
            <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-primary/15 perf-orange font-semibold">you are here</span>
          </div>
          <div class="text-lg font-mono font-black mb-1 perf-orange">ig</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Sparse n-grams (Blackbird algorithm). Local CLI, open source, standalone.
            Built for agent and editor-adjacent workflows.
          </p>
        </div>
        <div class="p-5 rounded-xl energy-card">
          <div class="text-lg font-mono font-black mb-1 perf-blue">Cursor</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Same algorithm (sparse n-grams). Integrated in editor, closed source.
            ig brings this power to the CLI.
          </p>
        </div>
        <div class="p-5 rounded-xl energy-card">
          <div class="text-lg font-mono font-black mb-1 perf-gold">Reflex</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Trigrams + Tree-sitter for semantic awareness. Rust, open source.
            AST-aware queries at the cost of indexing complexity.
          </p>
        </div>
        <div class="p-5 rounded-xl energy-card">
          <div class="text-lg font-mono font-black mb-1 perf-green">Zoekt</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Trigrams, server-based (Sourcegraph). Open source.
            Designed for large-scale monorepo search over HTTP.
          </p>
        </div>
        <div class="p-5 rounded-xl energy-card">
          <div class="text-lg font-mono font-black mb-1 perf-muted">ripgrep</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Brute-force regex, no index. Fastest unindexed tool.
            Great for small repos; ig outpaces it as repo size grows.
          </p>
        </div>
        <div class="p-5 rounded-xl energy-card">
          <div class="text-lg font-mono font-black mb-1 perf-red">Trigrep</div>
          <p class="text-xs text-muted-foreground leading-relaxed">
            Trigrams (Moderne). Cloud-based, closed source.
            Enterprise SaaS — ig is the self-hosted, open alternative.
          </p>
        </div>
      </div>
    </section>

    <!-- Visual speedometer -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-6 flex items-center gap-2">
        <span class="perf-orange">📈</span>
        Optimization Timeline
      </h2>

      <div class="space-y-4">
        {timeline.map((item) => (
          <div class="flex items-center gap-4">
            <div class="w-44 text-xs font-mono text-muted-foreground text-right flex-shrink-0">{item.label}</div>
            <div class="flex-1 h-6 rounded-full bg-secondary overflow-hidden">
              <div
                class={`h-full rounded-full perf-bar-${item.cls}`}
                style={`width: ${(item.ms / 18) * 100}%;`}
              ></div>
            </div>
            <div class={`w-14 text-xs font-mono font-bold text-right flex-shrink-0 ${item.cls}`}>{item.note}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Why sparse n-grams -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-4 flex items-center gap-2">
        <span>🌀</span>
        Why Sparse N-grams Beat Trigrams
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-6">
        <div class="p-5 rounded-xl energy-card">
          <div class="text-2xl font-mono font-black mb-2 perf-orange">Selectivity</div>
          <p class="text-sm text-muted-foreground">
            Longer n-grams appear in fewer files. A 7-gram like <code class="font-mono">"async f"</code>
            eliminates 99% of files immediately. Trigrams are too common.
          </p>
        </div>
        <div class="p-5 rounded-xl energy-card">
          <div class="text-2xl font-mono font-black mb-2 perf-blue">Index Size</div>
          <p class="text-sm text-muted-foreground">
            Fewer, more selective n-grams per file → smaller posting lists → smaller index.
            ig's index is typically 2-3MB for a 1000+ file project.
          </p>
        </div>
        <div class="p-5 rounded-xl energy-card">
          <div class="text-2xl font-mono font-black mb-2 perf-gold">Intersection</div>
          <p class="text-sm text-muted-foreground">
            Fewer candidates to intersect means less time in the merge step.
            Shadow Clone Selection picks the most selective n-grams automatically.
          </p>
        </div>
      </div>

      <div class="code-block rounded-xl p-5">
        <div class="text-xs font-mono text-white/50 mb-3">Selectivity comparison for "async fn":</div>
        <pre class="font-mono text-xs leading-relaxed overflow-x-auto"><code set:html={`<span class="text-red-400">Trigrams (weak):</span>   "asy"(3000 files) ∩ "syn"(2100 files) ∩ "ync"(1800 files) = 47 candidates
<span class="text-green-400">Sparse n-grams:</span>   "async fn"(3 files) = 3 candidates  → 15x fewer candidates to verify`}></code></pre>
      </div>
    </section>

    <!-- Daemon latency -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-4 flex items-center gap-2">
        <span>🐸</span>
        Sage Mode Latency Breakdown
      </h2>

      <div class="energy-card rounded-xl p-6">
        <div class="space-y-3">
          {daemonSteps.map((item) => (
            <div class="flex items-center justify-between py-1.5 border-b border-border/50 last:border-0">
              <span class="text-xs font-mono text-muted-foreground">{item.step}</span>
              <span class={`text-xs font-mono font-bold ${item.cls}`}>{item.time}</span>
            </div>
          ))}
          <div class="flex items-center justify-between pt-2 mt-2 border-t border-border">
            <span class="text-sm font-mono font-bold text-foreground">Total (p50)</span>
            <span class="text-sm font-mono font-black perf-green">~0.71ms</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Scaling curve -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="perf-blue">📐</span>
        Scaling Curve
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        ig's advantage compounds as project size grows. On small repos it matches rg; on large ones the index dominates.
      </p>

      <div class="overflow-x-auto rounded-xl border border-border">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-border bg-secondary/50">
              <th class="text-left py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">Project</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">Files</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">ig search</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">rg search</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">Speedup</th>
            </tr>
          </thead>
          <tbody class="font-mono text-xs">
            {[
              { project: "laravel-app", files: "49", ig: "19ms", rg: "21ms", speedup: "1.1×", highlight: false },
              { project: "distribution-app", files: "1,552", ig: "70ms", rg: "33ms", speedup: "0.5×", highlight: false },
              { project: "Next.js", files: "24,760", ig: "627ms", rg: "1,490ms", speedup: "2.4×", highlight: false },
              { project: "Linux kernel", files: "92,585", ig: "1,290ms", rg: "5,119ms", speedup: "4.0×", highlight: true },
            ].map((row) => (
              <tr class="border-b border-border/50 transition-colors hover:bg-secondary/30">
                <td class="py-3 px-4 text-foreground/80 font-mono">{row.project}</td>
                <td class="py-3 px-4 text-right text-muted-foreground">{row.files}</td>
                <td class={`py-3 px-4 text-right font-bold ${row.highlight ? "perf-orange" : "text-foreground/70"}`}>{row.ig}</td>
                <td class="py-3 px-4 text-right text-foreground/70">{row.rg}</td>
                <td class={`py-3 px-4 text-right font-bold ${row.speedup.startsWith("~") ? "text-foreground/70" : "perf-green"}`}>{row.speedup}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-4 p-4 rounded-xl energy-card border border-border/80">
        <p class="text-sm text-muted-foreground leading-relaxed">
          On the Linux kernel (92K files), a zero-result search:
          <span class="font-bold perf-green">28ms ig</span> vs
          <span class="font-bold perf-red">5,279ms rg</span> =
          <span class="font-black perf-orange">189× speedup</span>.
        </p>
      </div>
    </section>

    <!-- Daemon latency percentiles -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="perf-green">📊</span>
        Daemon Latency Percentiles
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        1,001 queries across all patterns. Overall: p50 = 0.71ms, p95 = 4.51ms, p99 = 4.69ms, avg = 1.51ms.
      </p>

      <div class="overflow-x-auto rounded-xl border border-border">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-border bg-secondary/50">
              <th class="text-left py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">Pattern</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">p50</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">p95</th>
              <th class="text-right py-3 px-4 text-xs font-mono text-muted-foreground font-normal uppercase tracking-wider">p99</th>
            </tr>
          </thead>
          <tbody class="font-mono text-xs">
            {[
              { pattern: '"ZZZNOTFOUND"', p50: "0.01ms", p95: "—", p99: "—", highlight: true },
              { pattern: '"DistributionController"', p50: "0.08ms", p95: "—", p99: "—", highlight: false },
              { pattern: '"Route::"', p50: "0.20ms", p95: "—", p99: "—", highlight: false },
              { pattern: '"middleware"', p50: "0.74ms", p95: "—", p99: "—", highlight: false },
              { pattern: '"exception"', p50: "0.75ms", p95: "—", p99: "—", highlight: false },
              { pattern: '"class "', p50: "3.88ms", p95: "—", p99: "—", highlight: false },
              { pattern: '"function"', p50: "4.43ms", p95: "—", p99: "—", highlight: false },
            ].map((row) => (
              <tr class="border-b border-border/50 transition-colors hover:bg-secondary/30">
                <td class="py-3 px-4 text-foreground/80"><code class="font-mono">{row.pattern}</code></td>
