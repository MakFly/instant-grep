    </a>
    <a href="/docs/performance" class="rounded-lg border p-4 flex flex-col gap-1.5 group hover:border-foreground/20 transition-colors">
      <h3 class="font-medium text-sm group-hover:text-foreground transition-colors">Performance</h3>
      <p class="text-xs text-muted-foreground">Benchmarks and optimization history</p>
