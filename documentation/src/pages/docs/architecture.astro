---
import DocsLayout from "@/layouts/docs.astro"
---

<DocsLayout title="Architecture" description="How instant-grep works under the hood — the Rasengan Pipeline">
  <div class="max-w-none">
    <!-- Page header -->
    <div class="mb-10">
      <div class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest mb-3 theme-blue">
        <span>🌀</span>
        <span>Secret Technique Scroll</span>
      </div>
      <h1 class="text-4xl font-mono font-black mb-4 gradient-text-blue">
        Architecture
      </h1>
      <p class="text-muted-foreground text-lg leading-relaxed">
        The inner workings of instant-grep — from regex to result in under a millisecond.
        Every technique honed to perfection.
      </p>
    </div>

    <!-- Rasengan Pipeline diagram -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-2 flex items-center gap-3">
        <span class="theme-orange">🌀</span>
        Rasengan Pipeline
      </h2>
      <p class="text-sm text-muted-foreground mb-6">
        The complete query pipeline — six stages of pure concentrated energy.
      </p>

      <div class="code-block rounded-xl p-6 overflow-x-auto">
        <pre class="font-mono text-xs sm:text-sm leading-relaxed"><code set:html={`<span class="theme-orange">╔══════════════════════════════════════════════════════════════════╗</span>
<span class="theme-orange">║</span>          <span class="theme-gold" style="font-weight:bold">✦ RASENGAN PIPELINE — FORBIDDEN SCROLL OF SEARCH ✦</span>          <span class="theme-orange">║</span>
<span class="theme-orange">╚══════════════════════════════════════════════════════════════════╝</span>

  User Input
      │
      ▼
<span class="theme-orange-bright">┌─────────────────────────────────────────┐</span>
<span class="theme-orange-bright">│  Stage 1 · regex-syntax Extractor       │</span>  <span class="pipeline-comment">query/extract.rs</span>
<span class="theme-orange-bright">│  "async fn" → literal fragments         │</span>
<span class="theme-orange-bright">└─────────────────┬───────────────────────┘</span>
                  │
                  ▼
<span class="theme-gold">┌─────────────────────────────────────────┐</span>
<span class="theme-gold">│  Stage 2 · Sparse N-gram Generation     │</span>  <span class="pipeline-comment">index/ngram.rs</span>
<span class="theme-gold">│  fragments → variable-length n-grams    │</span>
<span class="theme-gold">└─────────────────┬───────────────────────┘</span>
                  │
                  ▼
<span class="theme-blue">┌─────────────────────────────────────────┐</span>
<span class="theme-blue">│  Stage 3 · Shadow Clone Selection       │</span>  <span class="pipeline-comment">index/ngram.rs</span>
<span class="theme-blue">│  all n-grams → minimal covering set     │</span>  <span class="pipeline-comment">build_covering_ngrams()</span>
<span class="theme-blue">└─────────────────┬───────────────────────┘</span>
                  │
                  ▼
<span class="theme-green">┌─────────────────────────────────────────┐</span>
<span class="theme-green">│  Stage 4 · Hash Table Lookup            │</span>  <span class="pipeline-comment">index/reader.rs</span>
<span class="theme-green">│  n-grams → posting list offsets (mmap)  │</span>
<span class="theme-green">└─────────────────┬───────────────────────┘</span>
                  │
                  ▼
<span class="theme-orange-bright">┌─────────────────────────────────────────┐</span>
<span class="theme-orange-bright">│  Stage 5 · Posting List Intersection    │</span>  <span class="pipeline-comment">index/reader.rs</span>
<span class="theme-orange-bright">│  sorted file ID lists → candidates      │</span>
<span class="theme-orange-bright">└─────────────────┬───────────────────────┘</span>
                  │
                  ▼
<span class="theme-orange">┌─────────────────────────────────────────┐</span>
<span class="theme-orange">│  Stage 6 · Parallel Regex Verification  │</span>  <span class="pipeline-comment">Rayon threadpool</span>
<span class="theme-orange">│  candidates → verified matches          │</span>
<span class="theme-orange">└─────────────────────────────────────────┘</span>
                  │
                  ▼
            <span class="theme-gold">✓ Results</span>  <span class="pipeline-comment">(p50: 0.9ms)</span>`}></code></pre>
      </div>
    </section>

    <!-- Module structure -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="theme-orange">📂</span>
        Module Structure
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          {
            file: "src/index/ngram.rs",
            cls: "theme-orange",
            title: "Core Algorithm",
            fns: ["hash_bigram()", "build_all_ngrams()", "build_covering_ngrams()"],
            desc: "Sparse n-gram generation and covering set selection",
          },
          {
            file: "src/index/writer.rs",
            cls: "theme-gold",
            title: "Index Build Pipeline",
            fns: ["build_index()", "write_lexicon()", "write_postings()"],
            desc: "Walks filesystem, drives the SPIMI pipeline, serializes the index",
          },
          {
            file: "src/index/spimi.rs",
            cls: "theme-gold",
            title: "SPIMI Index Build",
            fns: ["SpimiBuildPipeline", "flush_segment()", "merge_segments()"],
            desc: "Single-Pass In-Memory Indexing with 128MB RAM budget — segments flushed to disk when budget is hit",
          },
          {
            file: "src/index/merge.rs",
            cls: "theme-blue",
            title: "Segment Merge",
            fns: ["merge_postings()", "merge_lexicons()"],
            desc: "Merges SPIMI segments into the final index with VByte-encoded postings",
          },
          {
            file: "src/index/vbyte.rs",
            cls: "theme-green",
            title: "VByte Compression",
            fns: ["vbyte_encode()", "vbyte_decode()", "delta_encode()"],
            desc: "Variable-byte delta encoding for posting lists — ~50–60% smaller postings.bin",
          },
          {
            file: "src/index/overlay.rs",
            cls: "theme-orange-bright",
            title: "Overlay Incremental Index",
            fns: ["OverlayIndex", "build_overlay()", "merge_overlay()"],
            desc: "For <100 changed files: builds a small overlay index, merges on read. Avoids full rebuild.",
          },
          {
            file: "src/index/reader.rs",
            cls: "theme-blue",
            title: "Index Query",
            fns: ["query_index()", "intersect_postings()", "mmap_open()"],
            desc: "mmap-backed hash table + posting list intersection. Decodes VByte postings on the fly.",
          },
          {
            file: "src/query/extract.rs",
            cls: "theme-green",
            title: "Regex → N-gram Conversion",
            fns: ["extract_ngrams()", "literal_fragments()", "NgramQuery"],
            desc: "Parses regex AST to extract searchable literal fragments",
          },
          {
            file: "src/daemon.rs",
            cls: "theme-orange-bright",
            title: "Sage Mode Daemon",
            fns: ["start_daemon()", "stop_daemon()", "daemon_status()", "install_launchd()", "uninstall_launchd()"],
            desc: "Unix socket server with full lifecycle: start/stop/status/install/uninstall + launchd auto-restart",
          },
          {
            file: "src/read.rs",
            cls: "theme-green",
            title: "Smart File Reading",
            fns: ["read_file()", "read_signatures()"],
            desc: "Full file reading or signatures-only mode — extracts function/struct definitions to reduce agent token cost",
          },
          {
            file: "src/smart.rs",
            cls: "theme-blue",
            title: "2-line File Summaries",
            fns: ["summarize_project()", "summarize_file()"],
            desc: "Heuristic 2-line summaries for every project file — high-level map before full reads",
          },
          {
            file: "src/pack.rs",
            cls: "theme-gold",
            title: "Project Context Generator",
            fns: ["pack_context()", "emit_deps()", "emit_routes()", "emit_env()"],
            desc: "Generates .ig/context.md: tree, symbols, dependencies, Next.js API routes, .env.example keys",
          },
          {
            file: "src/ls.rs",
            cls: "theme-orange-bright",
            title: "Compact Directory Listing",
            fns: ["ls_directory()", "format_tree()"],
            desc: "Groups files by directory with counts — token-efficient alternative to raw find output",
          },
          {
            file: "src/rewrite.rs",
            cls: "theme-orange",
            title: "Command Rewrite Engine",
            fns: ["rewrite_command()", "RewriteRule"],
            desc: "Translates grep/find/rg invocations to ig equivalents — used by the Claude Code PreToolUse hook",
          },
          {
            file: "src/tracking.rs",
            cls: "theme-blue",
            title: "Token Savings Tracking",
            fns: ["record_rewrite()", "load_history()"],
            desc: "Appends rewrite events to a JSONL log; read by ig gain to compute cumulative savings",
          },
          {
            file: "src/gain.rs",
            cls: "theme-gold",
            title: "Savings Dashboard",
            fns: ["print_gain()", "aggregate_history()"],
            desc: "Reads the JSONL tracking log and renders a token savings + cost summary table",
          },
          {
            file: "src/main.rs",
            cls: "theme-orange",
            title: "CLI Entry Point",
            fns: ["Commands enum", "clap::Parser", "dispatch()"],
            desc: "Command dispatch via clap — routes to index, search, status, watch, daemon, query, ls, read, smart, pack, gain",
          },
        ].map((module) => (
          <div class="energy-card rounded-xl p-5 bg-card/50">
            <div class="flex items-start justify-between mb-3">
              <code class={`text-xs font-mono ${module.cls}`}>{module.file}</code>
            </div>
            <h3 class="font-mono font-bold text-foreground text-sm mb-1">{module.title}</h3>
            <p class="text-xs text-muted-foreground mb-3">{module.desc}</p>
            <div class="flex flex-wrap gap-1.5">
              {module.fns.map((fn) => (
                <span class={`text-xs font-mono px-2 py-0.5 rounded module-badge ${module.cls}`}>
                  {fn}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- SPIMI + Incremental -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="theme-gold">⚡</span>
        v1.0.0 — SPIMI Build Pipeline &amp; Overlay Index
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-6">
        <div class="energy-card rounded-xl p-5 bg-card/50">
          <div class="text-sm font-mono font-bold mb-3 theme-gold">SPIMI Index Build</div>
          <p class="text-xs text-muted-foreground leading-relaxed mb-3">
            v1.0.0 uses a Single-Pass In-Memory Indexing (SPIMI) pipeline with a 128MB RAM budget.
            When the budget is hit, a segment is flushed to disk. After all files are processed,
            segments are merge-sorted into the final index.
          </p>
          <div class="code-block rounded-lg p-3 text-xs font-mono space-y-1">
            <div class="text-muted-foreground/60">spimi.rs → merge.rs → writer.rs</div>
            <div class="theme-gold">flush_segment() when RSS &gt; 128MB</div>
            <div class="theme-green">merge_segments() → final index</div>
            <div class="text-muted-foreground/60 mt-2">1,552 files → 2 segments → 450ms</div>
          </div>
        </div>
        <div class="energy-card rounded-xl p-5 bg-card/50">
          <div class="text-sm font-mono font-bold mb-3 theme-orange-bright">Overlay Incremental Index</div>
          <p class="text-xs text-muted-foreground leading-relaxed mb-3">
            When fewer than 100 files have changed since the last build, ig builds a small overlay index
            for the changed files only. Queries merge the base index and overlay on read —
            no full rebuild required.
          </p>
          <div class="code-block rounded-lg p-3 text-xs font-mono space-y-1">
            <div class="text-muted-foreground/60">overlay.rs</div>
            <div class="theme-orange-bright">OverlayIndex + build_overlay()</div>
            <div class="theme-green">Incremental (no-op): 25ms</div>
            <div class="text-muted-foreground/60 mt-2">Full rebuild: 450ms (if &gt;100 files changed)</div>
          </div>
        </div>
      </div>
    </section>

    <!-- On-disk format -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="theme-orange">💾</span>
        On-disk Format (.ig/ directory) — INDEX_VERSION 7
      </h2>
      <p class="text-sm text-muted-foreground mb-5">
        Three binary files, all memory-mapped for zero-copy access.
        <code class="font-mono">INDEX_VERSION</code> must be bumped when the format changes.
        v7: postings are VByte delta-encoded; <code class="font-mono">file_ngrams</code> removed from metadata (÷300 smaller).
      </p>

      <div class="code-block rounded-xl overflow-hidden">
        <pre class="p-5 font-mono text-sm leading-relaxed overflow-x-auto"><code set:html={`<span class="pipeline-comment">.ig/</span>
<span class="theme-blue">├── lexicon.bin</span>    <span class="pipeline-comment">— Hash table: u64(n-gram hash) → u32(posting offset) + u32(count)</span>
<span class="theme-orange-bright">├── postings.bin</span>   <span class="pipeline-comment">— VByte delta-encoded file ID lists per n-gram (~50–60% smaller vs v6)</span>
<span class="theme-gold">├── metadata.bin</span>   <span class="pipeline-comment">— u32 version + u64[] mtime + []string file paths (no file_ngrams in v7)</span>
<span class="theme-green">├── tree.txt</span>       <span class="pipeline-comment">— Compact directory tree snapshot (auto-generated by ig index)</span>
<span class="theme-gold">└── context.md</span>     <span class="pipeline-comment">— Structured AI agent snapshot: tree, symbols, deps, routes, env (v1.3+)</span>`}></code></pre>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-4">
        <div class="p-4 rounded-lg border border-border bg-secondary/30">
          <div class="text-xs font-mono font-bold mb-2 theme-blue">lexicon.bin</div>
          <div class="text-xs text-muted-foreground">Open-addressing hash table. Each slot: 8B key (n-gram hash) + 8B value (offset + count). Load factor: 0.7.</div>
        </div>
        <div class="p-4 rounded-lg border border-border bg-secondary/30">
          <div class="text-xs font-mono font-bold mb-2 theme-orange-bright">postings.bin</div>
          <div class="text-xs text-muted-foreground">VByte delta-encoded sorted file ID lists. Reader decodes on the fly during intersection. ~50–60% smaller than raw u32[] in v6.</div>
        </div>
        <div class="p-4 rounded-lg border border-border bg-secondary/30">
          <div class="text-xs font-mono font-bold mb-2 theme-gold">metadata.bin</div>
          <div class="text-xs text-muted-foreground">Maps file IDs to paths. Stores mtimes for incremental detection. First 4 bytes: INDEX_VERSION (7). No longer stores file_ngrams.</div>
        </div>
        <div class="p-4 rounded-lg border border-border bg-secondary/30">
          <div class="text-xs font-mono font-bold mb-2 theme-green">tree.txt</div>
          <div class="text-xs text-muted-foreground">Plain-text directory tree generated by <code class="font-mono">ls.rs</code> on every index rebuild. Consumed by <code class="font-mono">pack.rs</code> for context.md.</div>
        </div>
        <div class="p-4 rounded-lg border border-border bg-secondary/30 sm:col-span-2">
          <div class="text-xs font-mono font-bold mb-2 theme-gold">context.md</div>
          <div class="text-xs text-muted-foreground">Rich project snapshot written by <code class="font-mono">pack.rs</code>. Sections: directory tree, symbol definitions, Cargo.toml / package.json dependencies, Next.js API routes, .env.example keys. Replaces manual context-building for AI agents.</div>
        </div>
      </div>
    </section>

    <!-- Rasengan Algorithm -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-2 flex items-center gap-3">
        <span>🌀</span>
        Rasengan Algorithm — Sparse N-grams
      </h2>
      <div class="flex items-center gap-2 text-xs font-mono mb-4 theme-orange">
        <span>Port of github.com/danlark1/sparse_ngrams (GitHub Blackbird)</span>
      </div>

      <p class="text-sm text-muted-foreground mb-4 leading-relaxed">
        Traditional trigram search uses every contiguous 3-character substring — expensive and produces many false positives.
        The Rasengan Algorithm uses <strong class="text-foreground">variable-length n-grams</strong> that adapt to the string being indexed,
        concentrating energy where it matters.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-6">
        <div class="energy-card rounded-xl p-5 bg-card/50">
          <div class="text-xs font-mono font-bold mb-3 flex items-center gap-2 theme-red">
            <span>✗</span> Naive Trigrams (weak jutsu)
          </div>
          <div class="code-block rounded-lg p-3 text-xs font-mono">
            <div class="text-muted-foreground/60 mb-2">"async" → trigrams:</div>
            <div class="text-foreground/70">"asy", "syn", "ync"</div>
            <div class="text-muted-foreground/60 mt-3 mb-2">Problems:</div>
            <div class="text-xs theme-red">• Fixed length loses selectivity</div>
            <div class="text-xs theme-red">• Many false candidates</div>
            <div class="text-xs theme-red">• Large index size</div>
          </div>
        </div>
        <div class="energy-card rounded-xl p-5 bg-card/50">
          <div class="text-xs font-mono font-bold mb-3 flex items-center gap-2 theme-green">
            <span>✓</span> Sparse N-grams (Rasengan)
          </div>
          <div class="code-block rounded-lg p-3 text-xs font-mono">
            <div class="text-muted-foreground/60 mb-2">"async fn" → covering set:</div>
            <div class="text-foreground/70">"async", "fn"</div>
            <div class="text-muted-foreground/60 mt-3 mb-2">Advantages:</div>
            <div class="text-xs theme-green">• Variable length = high selectivity</div>
            <div class="text-xs theme-green">• Fewer candidates to verify</div>
            <div class="text-xs theme-green">• Smaller index, faster lookup</div>
          </div>
        </div>
      </div>

      <div class="p-5 rounded-xl border border-border bg-secondary/30">
        <p class="text-xs font-mono font-bold mb-2 theme-orange-bright">How hash_bigram() works:</p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Each n-gram is hashed by combining its characters using a polynomial rolling hash with a prime base.
          The hash fits in a <code class="font-mono">u64</code> — enabling the open-addressing hash table lookup
          to be a single memory access when the index is warm in the OS page cache (or the daemon's mmap).
        </p>
      </div>
    </section>

    <!-- Shadow Clone Selection -->
    <section class="mb-12">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-2 flex items-center gap-3">
        <span>👥</span>
        Shadow Clone Selection — Covering Algorithm
      </h2>

      <p class="text-sm text-muted-foreground mb-4 leading-relaxed">
        From all possible n-grams for a query, we need only the <strong class="text-foreground">minimal covering set</strong> —
        the smallest collection of n-grams that together guarantee we find all matching files.
        Like selecting the perfect shadow clones: enough to cover every angle, no redundancy.
      </p>

      <div class="code-block rounded-xl p-5 text-xs font-mono leading-relaxed overflow-x-auto">
        <div class="text-muted-foreground/60 mb-3">build_covering_ngrams() pseudocode:</div>
        <pre><code set:html={`<span class="theme-blue">fn</span> build_covering_ngrams(ngrams: Vec&lt;Ngram&gt;) → Vec&lt;Ngram&gt; {
    <span class="theme-orange-bright">sort</span> ngrams by (position, length desc)
    <span class="theme-orange-bright">greedily</span> select ngrams that cover uncovered positions
    <span class="theme-orange-bright">return</span> minimal subset that covers the full query string
}`}></code></pre>
      </div>
    </section>

    <!-- Sage Mode -->
    <section class="mb-4">
      <h2 class="text-2xl font-mono font-bold text-foreground mb-2 flex items-center gap-3">
        <span>🐸</span>
        Sage Mode — Daemon Architecture
      </h2>

      <p class="text-sm text-muted-foreground mb-4 leading-relaxed">
        In Sage Mode, the ninja draws power from nature without moving — the daemon keeps the index
        mmap'd in process memory, eliminating OS page cache warmup on every query.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div class="p-5 rounded-xl border border-border bg-secondary/30">
          <div class="text-sm font-mono font-bold mb-2 theme-blue">Without Sage Mode</div>
          <ul class="text-xs text-muted-foreground space-y-1">
            <li>• Cold start: open files, read mmap headers</li>
            <li>• OS page faults on first access</li>
            <li>• ~5-15ms for cold index</li>
            <li>• ~0.9ms when OS cache is warm</li>
          </ul>
        </div>
        <div class="p-5 rounded-xl border border-border bg-secondary/30">
          <div class="text-sm font-mono font-bold mb-2 theme-orange-bright">With Sage Mode (daemon)</div>
          <ul class="text-xs text-muted-foreground space-y-1">
            <li>• Index already in process memory</li>
            <li>• Unix socket: no TCP overhead</li>
            <li>• Sub-0.5ms consistent latency</li>
            <li>• Perfect for AI agent repeated queries</li>
          </ul>
        </div>
      </div>

      <div class="code-block rounded-xl overflow-hidden">
        <pre class="p-4 font-mono text-sm overflow-x-auto"><code set:html={`<span class="theme-orange"># Start Sage Mode (background)</span>
<span class="theme-blue">ig</span> daemon start .  <span class="pipeline-comment"># socket at .ig/daemon.sock</span>

<span class="theme-orange"># Check status</span>
<span class="theme-blue">ig</span> daemon status .

<span class="theme-orange"># Stop daemon</span>
<span class="theme-blue">ig</span> daemon stop .

<span class="theme-orange"># Install as launchd service (auto-restart on macOS)</span>
<span class="theme-blue">ig</span> daemon install .
<span class="theme-blue">ig</span> daemon uninstall .

<span class="theme-orange"># Query via socket (sub-ms)</span>
<span class="theme-blue">ig</span> query <span class="theme-gold">"async fn"</span> .`}></code></pre>
      </div>
    </section>
  </div>
</DocsLayout>

<style>
  .theme-orange { color: var(--primary); }
  .theme-orange-bright { color: var(--primary); }
  .theme-gold { color: oklch(0.55 0.14 80); }
  .theme-blue { color: var(--accent); }
  .theme-green { color: oklch(0.52 0.14 155); }
  .theme-red { color: oklch(0.55 0.2 25); }
  .pipeline-comment { color: var(--muted-foreground); opacity: 0.6; }

  :global(.dark) .theme-orange { color: #FF9500; }
  :global(.dark) .theme-orange-bright { color: #FF9500; }
  :global(.dark) .theme-gold { color: #FFD700; }
  :global(.dark) .theme-blue { color: #00B4FF; }
  :global(.dark) .theme-green { color: #34C759; }
  :global(.dark) .theme-red { color: #FF6B5A; }
  :global(.dark) .pipeline-comment { color: rgba(255,255,255,0.3); opacity: 1; }

  .module-badge {
    background: color-mix(in oklch, currentColor 10%, transparent);
    border: 1px solid color-mix(in oklch, currentColor 20%, transparent);
  }
</style>
