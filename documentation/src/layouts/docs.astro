---
import "@/styles/global.css"
import Topbar from "@/components/layout/topbar.astro"
import Sidebar from "@/components/layout/sidebar.astro"

interface Props {
  title: string
  description?: string
}

const { title, description } = Astro.props
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — ig docs</title>
  <meta name="description" content={description || "instant-grep documentation — trigram-indexed search for AI agents"} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={`https://instant-grep.pulseview.app${Astro.url.pathname}`} />

  <!-- Open Graph -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content={`${title} — ig docs`} />
  <meta property="og:description" content={description || "instant-grep documentation"} />
  <meta property="og:url" content={`https://instant-grep.pulseview.app${Astro.url.pathname}`} />
  <meta property="og:site_name" content="instant-grep" />
  <meta property="og:image" content="https://instant-grep.pulseview.app/og-image.png" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} — ig docs`} />
  <meta name="twitter:description" content={description || "instant-grep documentation"} />
  <meta name="twitter:image" content="https://instant-grep.pulseview.app/og-image.png" />
</head>
<body class="min-h-screen bg-background text-foreground antialiased font-sans">
  <Topbar />
  <div class="mx-auto max-w-6xl flex">
    <Sidebar currentPath={Astro.url.pathname} />
    <main class="flex-1 min-w-0 py-10 px-6 sm:px-10 lg:px-16">
      <article class="mx-auto max-w-[680px] docs-prose">
        <slot />
      </article>
    </main>
  </div>
</body>
</html>
